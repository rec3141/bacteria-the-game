# Make PWA / browser updates instant.
#
# DreamHost's defaults cache .js for 30 days, which pins an installed PWA to the
# build it first downloaded. Instead, have the app's entry files revalidate on
# every load: the browser sends a conditional request and gets a cheap 304 when
# nothing changed, or the new file the moment we deploy one. Media (sounds, icon)
# rarely changes, so it may still cache for a week.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|js|css|webmanifest)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header unset Expires
  </FilesMatch>
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store"
    Header unset Expires
  </FilesMatch>
  <FilesMatch "\.(mp3|svg|png|ico|swf)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

# Beta feedback is whatever a tester typed — that's theirs, not the internet's. feedback.php WRITES
# it; nobody GETs it over the web. (scores.json stays public: it's a leaderboard, that's the point.)
# Read it over ssh instead:  python3 -m json.tool < feedback.json
<Files "feedback.json">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>

# Rate-limit state for scenario-request.php: hashed visitor addresses, so it stays off the web for
# the same reason feedback.json does. Note the file NEXT to it, scenario-queue.json, is deliberately
# NOT blocked — the scenarios repo's workflow fetches that one over https to find newly submitted
# papers, and blocking it would silently stop every player submission from ever being built.
<Files "scenario-ratelimit.json">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>

# The queue is fetched cross-origin by GitHub Actions and must never be served stale, or a submission
# sits invisible until whatever cached copy expires.
<Files "scenario-queue.json">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-store"
    Header set Access-Control-Allow-Origin "*"
  </IfModule>
</Files>
